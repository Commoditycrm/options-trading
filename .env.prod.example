# Production env for docker-compose.prod.yml — copy to `.env` on the host and
# fill in real values. NEVER commit the real `.env` (it is gitignored).
#
# Generate strong secrets on the host:
#   POSTGRES_PASSWORD / REDIS_PASSWORD:
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   JWT_SECRET:
#     python3 -c "import secrets; print(secrets.token_urlsafe(64))"
#   CREDENTIAL_ENCRYPTION_KEY (Fernet — exact format required, do not invent):
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Public address ──────────────────────────────────────────────────────────
# Bare domain Caddy will obtain a TLS cert for (DNS A record must point here).
DOMAIN=options.example.com
# Full https origin, baked into the frontend for the browser SSE client.
PUBLIC_URL=https://options.example.com

# ── Postgres (internal only) ────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME_strong_random
POSTGRES_DB=trading_app

# ── Redis (internal only) ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_random

# ── Backend secrets ─────────────────────────────────────────────────────────
# DATABASE_URL and REDIS_URL are assembled by compose from the values above —
# do NOT set them here.
JWT_SECRET=CHANGE_ME_64_byte_base64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# NEVER rotate in place — invalidates every stored broker credential.
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# CORS + links. Single-domain deploy: both are the public origin.
CORS_ORIGINS=https://options.example.com
FRONTEND_BASE_URL=https://options.example.com

# ── Optional: IBKR (leave blank to keep the IBKR broker disabled) ───────────
# IBKR_CONSUMER_KEY=
# IBKR_DH_PARAM_PEM=
# IBKR_PRIVATE_ENCRYPTION_PEM=
# IBKR_PRIVATE_SIGNATURE_PEM=
