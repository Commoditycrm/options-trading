# Copy to deploy/.env.demo and fill in. NEVER commit the filled-in file.
#   cp deploy/.env.demo.example deploy/.env.demo

# --- Postgres (demo DB, isolated from production) ---
POSTGRES_USER=signalboxx
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=signalboxx_demo

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# Fernet key for encrypting broker credentials. Generate EXACTLY this way:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change-me

# --- Public URL (used for CORS + SSE origin) ---
# HTTP for first boot; switch to https://your-domain once certbot is done.
PUBLIC_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP

# --- Queue demo tuning ---
# 50 is safe with Postgres default max_connections=100. Bump to 100 only
# after raising max_connections (see deploy guide).
QUEUE_DEMO_WORKER_COUNT=50
