# Copy to the repo ROOT as `.env` (NOT deploy/.env) and fill in:
#   cp deploy/.env.prod.example .env
# docker-compose.prod.yml reads `.env` from the project root.
# NEVER commit the filled-in file — `.env` is gitignored.

# --- Postgres (internal-only, never published) ---
POSTGRES_USER=optionhaven
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=optionhaven

# --- Public hostname + URL ---
# DOMAIN is the bare host Caddy issues a TLS cert for (no scheme).
# Using sslip.io gives a real cert with no DNS setup: <ip>.sslip.io
DOMAIN=YOUR_IP.sslip.io
PUBLIC_URL=https://YOUR_IP.sslip.io

# --- Auth ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# Fernet key for encrypting broker credentials. Generate EXACTLY this way:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change-me

# --- Queue worker pool (in-process; no Redis on this stack) ---
QUEUE_DEMO_WORKER_COUNT=50
